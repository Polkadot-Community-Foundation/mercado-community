# Summit Asset Hub configuration for all deployments.
# Loaded into the build env by the deploy workflow (lines starting with '#'
# are stripped, so commented values become undefined at runtime).
VITE_NETWORK=summit
VITE_GENESIS_HASH=0xf388dc6d6cdf6fb77eac3c4a91f31bc0c8642b142f1a757512ab7849f9f70660
VITE_WS_RPC_ENDPOINT=wss://summit-asset-hub-rpc.polkadot.io

# Contract addresses — TODO: fill in after deploying the contracts to Summit
# Asset Hub (`pnpm --filter @mercado/contracts deploy:summit`). Until then these
# stay commented so the build does NOT bake stale Paseo addresses.
# VITE_MERCADO_ADDRESS=0x...
# VITE_MERCADO_RATINGS_ADDRESS=0x...
# VITE_RESTAURANT_META_ADDRESS=0x...
# VITE_MERCADO_DISPUTES_ADDRESS=0x...
# VITE_MATCHMAKERS_ADDRESS=0x...
# VITE_MOCKMOBRULE_ADDRESS=0x...

# Bulletin Chain (for evidence/metadata uploads) — Summit Bulletin
VITE_BULLETIN_ENDPOINT=wss://summit-bulletin-rpc.polkadot.io
VITE_IPFS_GATEWAY=https://summit-ipfs.polkadot.io/ipfs/

# Enable real contract interactions
VITE_USE_REAL_CONTRACTS=true
