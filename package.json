{
  "name": "mercado",
  "private": true,
  "license": "GPL-3.0",
  "type": "module",
  "pnpm": {
    "overrides": {
      "@polkadot-api/json-rpc-provider": "^0.2.0"
    }
  },
  "scripts": {
    "dev": "pnpm --filter @mercado/web dev",
    "dev:admin": "pnpm --filter @mercado/mockmobrule-admin dev",
    "build": "turbo run build",
    "build:web": "pnpm --filter @mercado/web... build",
    "lint": "eslint . && prettier --check .",
    "format": "eslint . --fix && prettier --write .",
    "test:unit": "pnpm --filter @mercado/web test",
    "test:e2e": "pnpm --filter @mercado/e2e test",
    "typecheck": "turbo run typecheck",
    "storybook": "pnpm --filter @mercado/web storybook"
  },
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0"
  }
}
