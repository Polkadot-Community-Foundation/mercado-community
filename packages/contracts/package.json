{
  "name": "@mercado/contracts",
  "version": "1.0.0",
  "private": true,
  "license": "GPL-3.0",
  "description": "Smart contracts for mercado food delivery marketplace",
  "exports": {
    "./artifacts/Mercado.json": "./artifacts/contracts/Mercado.sol/Mercado.json",
    "./artifacts/MockMobRule.json": "./artifacts/contracts/MockMobRule.sol/MockMobRule.json",
    "./typechain-types": "./typechain-types/index.ts",
    "./typechain-types/*": "./typechain-types/*.ts"
  },
  "dependencies": {
    "@mercado/types": "workspace:*"
  },
  "scripts": {
    "build": "hardhat compile && tsc --build",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:unit": "vitest run",
    "coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:summit": "hardhat run scripts/deploy.ts --network summit",
    "deploy:summit:papi": "NETWORK=summit tsx scripts/deploy-papi.ts",
    "deploy:paseo": "hardhat run scripts/deploy.ts --network paseo",
    "deploy:paseo-v2": "hardhat run scripts/deploy.ts --network paseo-v2",
    "deploy:previewnet": "hardhat run scripts/deploy.ts --network previewnet",
    "seed:summit": "tsx scripts/seed.ts --network summit",
    "seed:paseo": "tsx scripts/seed.ts --network paseo",
    "seed:local": "tsx scripts/seed.ts --network localhost",
    "upgrade:summit": "hardhat run scripts/upgrade.ts --network summit",
    "upgrade:paseo": "hardhat run scripts/upgrade.ts --network paseo",
    "upgrade:local": "hardhat run scripts/upgrade.ts --network localhost",
    "check-size": "hardhat size-contracts",
    "clean": "hardhat clean && rm -rf typechain-types dist",
    "lint": "solhint 'contracts/**/*.sol'",
    "lint:fix": "solhint 'contracts/**/*.sol' --fix --noPrompt",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@openzeppelin/contracts": "5.0.1",
    "@openzeppelin/contracts-upgradeable": "5.0.1",
    "@openzeppelin/hardhat-upgrades": "^3.0.0",
    "@parity/hardhat-polkadot": "0.2.7",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "chai": "^4.3.10",
    "dotenv": "^16.4.5",
    "ethers": "^6.10.0",
    "hardhat": "^2.28.2",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-gas-reporter": "^1.0.9",
    "solhint": "^4.1.1",
    "solidity-coverage": "^0.8.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
