{
  "extends": ["//"],
  "tasks": {
    "build": {
      "inputs": [
        "contracts/**",
        "scripts/**",
        "hardhat.config.ts",
        "tsconfig.json",
        ".papi/polkadot-api.json",
        ".papi/metadata/**",
        ".papi/contracts/**"
      ],
      "outputs": [
        "artifacts/**",
        "typechain-types/**",
        "dist/**",
        ".papi/descriptors/**"
      ]
    },
    "typecheck": {
      "dependsOn": ["build"],
      "outputs": ["**/*.tsbuildinfo"]
    }
  }
}
